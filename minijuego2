<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Juego de Unir Letras</title>
    <style>
        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            background-color: #2c3e50;
            color: white;
            font-family: sans-serif;
            overflow: hidden;
        }
        canvas {
            background-color: #ecf0f1;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            cursor: crosshair;
        }
        #ui { margin-bottom: 10px; text-align: center; }
        .btn {
            padding: 10px 20px;
            background: #e74c3c;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div id="ui">
        <h2>Une los Pares</h2>
        <p>No toques las líneas existentes. <button class="btn" onclick="initGame()">Reiniciar</button></p>
    </div>
    <canvas id="gameCanvas" width="600" height="400"></canvas>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    
    let dots = [];
    let lines = []; // Líneas completadas
    let currentLine = null; // Línea que se está dibujando
    let letters = ['A', 'B', 'C', 'D', 'E'];
    let gameOver = false;

    function initGame() {
        dots = [];
        lines = [];
        currentLine = null;
        gameOver = false;
        
        let positions = [];
        // Crear 2 de cada letra
        letters.forEach(char => {
            for(let i=0; i<2; i++) {
                let pos = {
                    x: Math.random() * (canvas.width - 60) + 30,
                    y: Math.random() * (canvas.height - 60) + 30,
                    char: char,
                    id: Math.random(),
                    connected: false
                };
                dots.push(pos);
            }
        });
        draw();
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Dibujar líneas guardadas
        lines.forEach(line => {
            ctx.beginPath();
            ctx.strokeStyle = '#3498db';
            ctx.lineWidth = 4;
            ctx.moveTo(line.start.x, line.start.y);
            line.path.forEach(p => ctx.lineTo(p.x, p.y));
            ctx.stroke();
        });

        // Dibujar línea actual
        if (currentLine) {
            ctx.beginPath();
            ctx.strokeStyle = '#f1c40f';
            ctx.lineWidth = 4;
            ctx.moveTo(currentLine.start.x, currentLine.start.y);
            currentLine.path.forEach(p => ctx.lineTo(p.x, p.y));
            ctx.stroke();
        }

        // Dibujar letras
        dots.forEach(dot => {
            ctx.fillStyle = dot.connected ? '#bdc3c7' : '#2c3e50';
            ctx.beginPath();
            ctx.arc(dot.x, dot.y, 15, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = 'white';
            ctx.font = 'bold 16px Arial';
            ctx.textAlign = 'center';
            ctx.fillText(dot.char, dot.x, dot.y + 6);
        });

        if(gameOver) {
            ctx.fillStyle = 'rgba(0,0,0,0.7)';
            ctx.fillRect(0,0,canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            ctx.font = '40px Arial';
            ctx.fillText("¡PERDISTE!", canvas.width/2, canvas.height/2);
        } else if (lines.length === 5) {
            ctx.fillStyle = 'rgba(46, 204, 113, 0.8)';
            ctx.fillRect(0,0,canvas.width, canvas.height);
            ctx.fillStyle = 'white';
            ctx.font = '40px Arial';
            ctx.fillText("¡GANASTE!", canvas.width/2, canvas.height/2);
        }
    }

    canvas.addEventListener('mousedown', e => {
        if(gameOver || lines.length === 5) return;
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;

        dots.forEach(dot => {
            if (!dot.connected && Math.hypot(dot.x - mx, dot.y - my) < 20) {
                currentLine = { start: dot, path: [{x: mx, y: my}] };
            }
        });
    });

    canvas.addEventListener('mousemove', e => {
        if (!currentLine || gameOver) return;
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;

        const lastPoint = currentLine.path[currentLine.path.length - 1];
        
        // Colisión con otras líneas
        lines.forEach(line => {
            for(let i=0; i < line.path.length - 1; i++) {
                if (intersect(lastPoint.x, lastPoint.y, mx, my, line.path[i].x, line.path[i].y, line.path[i+1].x, line.path[i+1].y)) {
                    gameOver = true;
                }
            }
        });

        currentLine.path.push({x: mx, y: my});
        draw();
    });

    canvas.addEventListener('mouseup', e => {
        if (!currentLine) return;
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;

        let foundMatch = false;
        dots.forEach(dot => {
            if (!dot.connected && dot !== currentLine.start && 
                dot.char === currentLine.start.char && 
                Math.hypot(dot.x - mx, dot.y - my) < 20) {
                
                dot.connected = true;
                currentLine.start.connected = true;
                lines.push(currentLine);
                foundMatch = true;
            }
        });

        currentLine = null;
        draw();
    });

    // Función matemática para detectar si dos líneas se cruzan
    function intersect(x1, y1, x2, y2, x3, y3, x4, y4) {
        let det = (x2 - x1) * (y4 - y3) - (x4 - x3) * (y2 - y1);
        if (det === 0) return false;
        let lambda = ((y4 - y3) * (x4 - x1) + (x3 - x4) * (y4 - y1)) / det;
        let gamma = ((y1 - y2) * (x4 - x1) + (x2 - x1) * (y4 - y1)) / det;
        return (0 < lambda && lambda < 1) && (0 < gamma && gamma < 1);
    }

    initGame();
</script>
</body>
</html>
