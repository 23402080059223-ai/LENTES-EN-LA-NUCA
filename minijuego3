<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Minijuego de Hackeo - Colores</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Press Start 2P', cursive;
        }

        #capa-hack {
            width: 400px;
            background: #000;
            border: 4px solid #00aaff;
            padding: 30px;
            text-align: center;
            box-shadow: 0 0 20px #00aaff;
        }

        .titulo {
            font-size: 12px;
            color: #00aaff;
            margin-bottom: 25px;
            line-height: 1.4;
        }

        #contenedor-botones {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            width: 210px;
            margin: 0 auto;
        }

        .btn-hack {
            width: 100px;
            height: 100px;
            border: 3px solid #fff;
            cursor: pointer;
            transition: transform 0.1s;
        }

        .btn-hack:active {
            transform: scale(0.95);
        }

        #status-hack {
            font-size: 10px;
            margin-top: 25px;
            color: #fff;
            height: 20px;
        }

        .boton-inicio {
            margin-top: 20px;
            background: transparent;
            color: #00aaff;
            border: 2px solid #00aaff;
            padding: 10px;
            font-family: 'Press Start 2P', cursive;
            cursor: pointer;
        }

        .boton-inicio:hover {
            background: #00aaff;
            color: #000;
        }
    </style>
</head>
<body>

<div id="capa-hack">
    <div class="titulo">SINTONIZANDO SEÑAL...<br>REPETIR SECUENCIA</div>
    
    <div id="contenedor-botones">
        <div id="btn-0" class="btn-hack" onclick="presionarBotonHack(0)" style="background: #500;"></div>
        <div id="btn-1" class="btn-hack" onclick="presionarBotonHack(1)" style="background: #050;"></div>
        <div id="btn-2" class="btn-hack" onclick="presionarBotonHack(2)" style="background: #005;"></div>
        <div id="btn-3" class="btn-hack" onclick="presionarBotonHack(3)" style="background: #550;"></div>
    </div>

    <div id="status-hack">PRESIONA INICIAR</div>
    <button class="boton-inicio" onclick="iniciarMisionHack()">INICIAR HACKEO</button>
</div>

<script>
    // Configuración de colores (Claros para brillar, Oscuros para estado normal)
    const colClaros = ['#ff0000', '#00ff00', '#0000ff', '#ffff00'];
    const colOscuros = ['#500', '#050', '#005', '#550'];

    let secuencia = [];
    let secuenciaUsuario = [];
    let nivelHack = 0;
    let esperandoUsuario = false;
    let juegoActivo = false;

    const statusTexto = document.getElementById("status-hack");

    // Inicia o reinicia el minijuego
    function iniciarMisionHack() {
        juegoActivo = true;
        secuencia = [];
        nivelHack = 1;
        siguientePasoHack();
    }

    // Añade un nuevo color aleatorio a la lista
    function siguientePasoHack() {
        esperandoUsuario = false;
        secuenciaUsuario = [];
        statusTexto.innerText = "OBSERVA LA SEÑAL...";
        statusTexto.style.color = "#00aaff";
        
        secuencia.push(Math.floor(Math.random() * 4));
        
        // Pequeña pausa antes de mostrar la secuencia
        setTimeout(reproducirSecuencia, 800);
    }

    // Muestra la secuencia al jugador uno por uno
    async function reproducirSecuencia() {
        for (let i = 0; i < secuencia.length; i++) {
            await iluminarBoton(secuencia[i]);
            await esperar(300); // Espacio entre luces
        }
        statusTexto.innerText = "¡TU TURNO!";
        statusTexto.style.color = "#00ff00";
        esperandoUsuario = true;
    }

    // Hace que un botón brille y luego vuelva a su color oscuro
    function iluminarBoton(id) {
        return new Promise(resolve => {
            const boton = document.getElementById(`btn-${id}`);
            boton.style.background = colClaros[id];
            boton.style.boxShadow = `0 0 20px ${colClaros[id]}`;
            
            setTimeout(() => {
                boton.style.background = colOscuros[id];
                boton.style.boxShadow = "none";
                resolve();
            }, 600); // Tiempo que se queda encendido
        });
    }

    // Maneja los clics del usuario
    function presionarBotonHack(id) {
        if (!esperandoUsuario || !juegoActivo) return;

        // Feedback visual rápido al tocar
        const boton = document.getElementById(`btn-${id}`);
        boton.style.background = colClaros[id];
        setTimeout(() => boton.style.background = colOscuros[id], 150);

        secuenciaUsuario.push(id);
        const indexActual = secuenciaUsuario.length - 1;

        // Verificar si el botón es el correcto
        if (secuenciaUsuario[indexActual] !== secuencia[indexActual]) {
            statusTexto.innerText = "FRECUENCIA PERDIDA";
            statusTexto.style.color = "#ff0000";
            juegoActivo = false;
            setTimeout(() => alert("ERROR DE HACKEO. Inténtalo de nuevo."), 100);
            return;
        }

        // Verificar si terminó la ronda actual
        if (secuenciaUsuario.length === secuencia.length) {
            esperandoUsuario = false;
            
            if (nivelHack === 4) { // Gana al completar 4 rondas
                statusTexto.innerText = "SISTEMA VULNERADO";
                juegoActivo = false;
                setTimeout(() => alert("¡HACKEO EXITOSO!\nCódigo obtenido: 1092"), 500);
            } else {
                nivelHack++;
                statusTexto.innerText = "¡BIEN! SIGUIENTE NIVEL...";
                setTimeout(siguientePasoHack, 1200);
            }
        }
    }

    // Función auxiliar para crear pausas
    function esperar(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }
</script>

</body>
</html>
