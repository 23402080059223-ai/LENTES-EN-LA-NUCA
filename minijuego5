<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Minijuego: Sincronización de Núcleo</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0a0a0a;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Press Start 2P', cursive;
            color: white;
        }

        #contenedor-reflejos {
            width: 450px;
            background: #111;
            border: 4px solid #00ff88;
            padding: 30px;
            text-align: center;
            box-shadow: 0 0 15px #00ff88;
        }

        /* La barra gris de fondo */
        #barra-fondo {
            width: 100%;
            height: 40px;
            background: #333;
            margin: 30px 0;
            position: relative;
            border: 2px solid #fff;
        }

        /* La zona verde donde hay que acertar */
        #zona-objetivo {
            position: absolute;
            height: 100%;
            width: 40px; /* Ancho de la zona de éxito */
            background: #00ff88;
            box-shadow: 0 0 15px #00ff88;
        }

        /* El puntero que se mueve */
        #puntero {
            position: absolute;
            height: 120%;
            width: 6px;
            background: #fff;
            top: -10%;
            left: 0%;
            box-shadow: 0 0 10px #fff;
        }

        #status {
            font-size: 10px;
            height: 20px;
            margin-bottom: 10px;
        }

        .puntos-contenedor {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
        }

        .led {
            width: 15px;
            height: 15px;
            background: #222;
            border: 1px solid #555;
        }

        .led.encendido {
            background: #00ff88;
            box-shadow: 0 0 10px #00ff88;
        }

        button {
            background: transparent;
            color: #00ff88;
            border: 2px solid #00ff88;
            padding: 10px 20px;
            font-family: 'Press Start 2P', cursive;
            cursor: pointer;
            margin-top: 10px;
        }

        button:hover { background: #00ff88; color: #000; }
    </style>
</head>
<body>

<div id="contenedor-reflejos">
    <div style="font-size: 12px; color: #00ff88;">ESTABILIZADOR DE NÚCLEO</div>
    <p style="font-size: 8px; color: #aaa;">Presiona ESPACIO o CLIC en la zona verde</p>
    
    <div id="barra-fondo">
        <div id="zona-objetivo"></div>
        <div id="puntero"></div>
    </div>

    <div id="status">CONECTA 3 VECES</div>

    <div class="puntos-contenedor">
        <div class="led" id="led-0"></div>
        <div class="led" id="led-1"></div>
        <div class="led" id="led-2"></div>
    </div>

    <br>
    <button id="btn-inicio" onclick="iniciarMision()">INICIAR CARGA</button>
</div>

<script>
    let posicionPuntero = 0;
    let direccion = 1; 
    let velocidad = 2; // Velocidad de la barra
    let aciertos = 0;
    const aciertosNecesarios = 3;
    let juegoActivo = false;
    let animacionID;

    const puntero = document.getElementById('puntero');
    const zona = document.getElementById('zona-objetivo');
    const statusTxt = document.getElementById('status');
    const btnInicio = document.getElementById('btn-inicio');

    // Mover la zona verde a un lugar aleatorio
    function moverZona() {
        const maxPos = 100 - (40 / 450 * 100); // Calcular margen para que no se salga
        const randomX = Math.random() * 80 + 5; 
        zona.style.left = randomX + '%';
    }

    function iniciarMision() {
        aciertos = 0;
        velocidad = 2;
        juegoActivo = true;
        btnInicio.style.display = 'none';
        statusTxt.innerText = "¡AHORA!";
        statusTxt.style.color = "#fff";
        document.querySelectorAll('.led').forEach(l => l.classList.remove('encendido'));
        moverZona();
        actualizar();
    }

    function actualizar() {
        if (!juegoActivo) return;

        posicionPuntero += direccion * velocidad;

        if (posicionPuntero >= 100 || posicionPuntero <= 0) {
            direccion *= -1; // Rebota
        }

        puntero.style.left = posicionPuntero + '%';
        animacionID = requestAnimationFrame(actualizar);
    }

    // Función para comprobar el éxito
    function intentar() {
        if (!juegoActivo) return;

        const pRect = puntero.getBoundingClientRect();
        const zRect = zona.getBoundingClientRect();

        // Comprobar si el puntero está dentro de los límites de la zona verde
        if (pRect.left >= zRect.left && pRect.right <= zRect.right) {
            document.getElementById(`led-${aciertos}`).classList.add('encendido');
            aciertos++;
            velocidad += 0.8; // Aumentar dificultad
            
            if (aciertos >= aciertosNecesarios) {
                ganar();
            } else {
                moverZona();
            }
        } else {
            statusTxt.innerText = "¡FALLO! REINTENTANDO...";
            statusTxt.style.color = "#ff4444";
            aciertos = 0;
            velocidad = 2;
            document.querySelectorAll('.led').forEach(l => l.classList.remove('encendido'));
            moverZona();
        }
    }

    function ganar() {
        juegoActivo = false;
        cancelAnimationFrame(animacionID);
        statusTxt.innerText = "NÚCLEO ESTABLE";
        statusTxt.style.color = "#00ff88";
        setTimeout(() => {
            alert("Sincronización completa.\nCódigo final: 8832");
            btnInicio.style.display = 'inline-block';
            btnInicio.innerText = "REINICIAR";
        }, 300);
    }

    // Escuchar tanto el teclado como el clic
    window.addEventListener('keydown', (e) => { if(e.code === 'Space') intentar(); });
    document.getElementById('barra-fondo').addEventListener('mousedown', intentar);

</script>
</body>
</html>
