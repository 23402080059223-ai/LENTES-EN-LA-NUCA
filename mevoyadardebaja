<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Voz Censurada - Proyecto</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body { 
            margin: 0; 
            overflow: hidden; 
            background: #000; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            font-family: 'Press Start 2P', cursive; 
        }

        #contenedor-juego {
            position: relative; 
            width: 1000px;
            height: 550px;
            border: 2px solid #fff; 
        }

        canvas { 
            display: block; 
            image-rendering: pixelated; 
        }

        #menu-inicio {
            position: absolute; 
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to right, rgba(0,0,0,1) 0%, rgba(0,0,0,0.7) 50%, rgba(0,0,0,0.3) 100%), 
                        url('fondo.gif');
            background-size: cover; 
            background-position: center; 
            display: flex; flex-direction: column; 
            justify-content: center; align-items: flex-start; 
            padding-left: 50px; z-index: 10; box-sizing: border-box;
        }

        h1 { color: white; font-size: 35px; text-shadow: 4px 4px #ff0000; margin-bottom: 40px; }

        .boton-menu {
            background: transparent; color: white; border: 2px solid white;
            padding: 15px; margin: 10px 0; font-size: 14px; 
            font-family: 'Press Start 2P', cursive; cursor: pointer; width: 300px;
            text-align: left; transition: 0.2s;
        }

        .boton-menu:hover { background: white; color: black; transform: translateX(10px); }

        #icono-mision {
            position: absolute;
            color: #ff0000;
            font-size: 100px; 
            font-weight: bold;
            text-shadow: 5px 5px 0px #fff; 
            z-index: 5;
            pointer-events: none;
            animation: flotar 0.8s infinite alternate ease-in-out;
        }

        @keyframes flotar {
            from { transform: translateY(0); }
            to { transform: translateY(-20px); }
        }

         #pantalla-ajustes {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.7) 80%, rgba(0,0,0,0.7) 100%), 
                        url('fondo.gif');
            background-size: cover; 
            background-position: center; 
            display: flex; justify-content: center; align-items: center;
            z-index: 50;
        }

        .ajustes-box {
            width: 500px; height:200px ; background-color: #000; padding: 30px;
            border: 4px solid #fdfdfd; border-radius: 4px;
            box-shadow: inset 0 0 0 4px #4a4a4a; 
            position: relative;
        }

        .ajustes-box h2 { color: #ff0000; font-size: 16px; text-align: center; margin-bottom: 25px; }

        .opcion-ajuste {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px; color: white; font-size: 10px;
        }

        .oculto { display: none !important; }

        .boton-volver-fuera {
            position: absolute; top: 30px; left: 30px; background: transparent;
            color: white; border: 3px solid white; font-size: 24px; cursor: pointer;
            padding: 10px; z-index: 60; transform: scaleX(-1);
        }

        .retrato-contenedor {
            position: absolute; bottom: 140px; left: 470px;
            width: 120px; height: 120px; background: rgba(0, 0, 0, 0.8);
            border: 3px solid white; display: flex; justify-content: center; z-index: 100;
        }

        .retrato-img { width: 100%; image-rendering: pixelated; }

        /* MINIJUEGO 1 (TECLAS) */
        #capa-minijuego {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 400px; background: #1a1a1a; border: 4px solid #00ff88;
            padding: 20px; z-index: 200; text-align: center;
        }

        /* MINIJUEGO 2 (UNIR LETRAS) */
        #capa-unir {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 450px; background: #1a1a1a; border: 4px solid #ff0000;
            padding: 20px; z-index: 200; text-align: center;
        }

        #timer-mini { width: 100%; height: 10px; background: #333; margin: 15px 0; border: 1px solid #fff; }
        #bar-mini { width: 100%; height: 100%; background: #00ff88; transition: width 0.1s linear; }
        #tecla-display { font-size: 50px; color: #fff; margin: 10px 0; }
        #puntos-mini { display: flex; justify-content: center; gap: 8px; margin-bottom: 10px; }
        .punto { width: 12px; height: 12px; border-radius: 50%; background: #444; border: 1px solid #fff; }
        .punto.lleno { background: #00ff88; }
        #img-mini { width: 100%; height: 150px; object-fit: cover; border: 2px solid #fff; }

        /* Estilo para los diálogos (Copiado de tu CSS externo mencionado) */
        .dialogue-container {
            position: absolute; bottom: 20px; left: 50px; width: 900px; height: 150px;
            background: rgba(0,0,0,0.9); border: 4px solid white; color: white; padding: 20px;
            box-sizing: border-box; z-index: 80;
        }
        .character-name { color: #ff0000; font-size: 14px; margin-bottom: 10px; }
        .message-text { font-size: 12px; line-height: 1.5; }

    </style>
</head>
<body>

<div id="contenedor-juego">
    <div id="icono-mision" class="oculto">!</div>
    <button id="btn-volver-juego" class="boton-volver-fuera oculto" onclick="volverAlMenu()">&#10140;</button>

    <div id="menu-inicio">
        <h1>VOZ CENSURADA</h1>
        <button class="boton-menu" onclick="comenzarJuego()">INICIAR PARTIDA</button>
        <button class="boton-menu" onclick="abrirAjustes()">AJUSTES</button>
    </div>

    <div id="capa-minijuego" class="oculto">
        <div style="font-size: 10px; color: #00ff88;">Presiona las teclas indicadas</div>
        <div id="timer-mini"><div id="bar-mini"></div></div>
        <div id="puntos-mini">
            <div class="punto"></div><div class="punto"></div><div class="punto"></div><div class="punto"></div><div class="punto"></div>
        </div>
        <div id="tecla-display">?</div>
        <img id="img-mini" src="https://picsum.photos/400/300?sig=1">
        <div style="font-size: 8px; margin-top: 10px;">PROGRESO: <span id="img-count">0</span>/3</div>
    </div>

    <div id="capa-unir" class="oculto">
        <div style="font-size: 10px; color: #ff0000; margin-bottom: 10px;">CONECTA LOS PARES</div>
        <canvas id="canvasUnir" width="400" height="300" style="background: #222; border: 2px solid #fff; cursor: crosshair;"></canvas>
        <div style="font-size: 8px; margin-top: 10px; color: #aaa;">EVITA QUE LAS LÍNEAS SE CRUCEN</div>
    </div>

     <div id="pantalla-ajustes" class="oculto">
        <button class="boton-volver-fuera" onclick="cerrarAjustes()">&#10140;</button>
        <div class="ajustes-box">
            <h2>AJUSTES DE SISTEMA</h2>
            <div class="opcion-ajuste">
                <span>VOLUMEN</span>
                <input type="range" id="slider-volumen" min="0" max="100" value="50" oninput="ajustarVolumen()">
            </div>
            <div class="opcion-ajuste">
                <span>BRILLO</span>
                <input type="range" id="rango-brillo" min="50" max="150" value="100" oninput="ajustarBrillo()">
            </div>
            <div class="opcion-ajuste">
                <span>PANTALLA COMPLETA</span>
                <button id="btnFullscreen" onclick="toggleFullscreen()" style="font-family:'Press Start 2P'; font-size: 8px; padding: 5px; cursor: pointer;">OFF</button>
            </div> 
        </div> 
    </div>

    <div id="interaccion-aviso" class="oculto" style="position: absolute; bottom: 180px; left: 50%; transform: translateX(-50%); color: white; font-size: 10px; z-index: 90;">Presiona [E] para hablar</div>

    <div id="dialogueBox" class="dialogue-container oculto">
        <div id="retrato" class="retrato-contenedor">
            <img id="imgRetrato" src="clauicon.png" class="retrato-img">
        </div>
        <div class="character-name" id="charName">Claudia:</div>
        <p class="message-text" id="typewriterText"></p>
        <div class="next-arrow"></div>
    </div>

    <canvas id="juego"></canvas>
</div>

<script>
    const canvas = document.getElementById("juego");
    const ctx = canvas.getContext("2d");
    const ajustes = document.getElementById("pantalla-ajustes");
    const menu = document.getElementById("menu-inicio");
    const avisoE = document.getElementById("interaccion-aviso");
    const iconoMision = document.getElementById("icono-mision");
    const boxDialogo = document.getElementById("dialogueBox");
    const textoDialogo = document.getElementById("typewriterText");
    const nombreDialogo = document.getElementById("charName");
    const imgRetrato = document.getElementById("imgRetrato");
    const btnVolverJuego = document.getElementById("btn-volver-juego");

    // --- AUDIO ---
    const musicaFondo = new Audio('feliz.mp3'); 
    musicaFondo.loop = true;
    musicaFondo.volume = 0.5;

    // --- VARIABLES MINIJUEGO 1 ---
    const capaMini = document.getElementById("capa-minijuego");
    const teclaDisplay = document.getElementById("tecla-display");
    const barMini = document.getElementById("bar-mini");
    const imgMini = document.getElementById("img-mini");
    const imgCountText = document.getElementById("img-count");
    const puntosCirculo = document.querySelectorAll(".punto");

    let miniActivo = false;
    let letraActual = '';
    let teclasLogradas = 0;
    let imagenesLogradas = 0;
    let tiempoMini = 100;

    // --- VARIABLES MINIJUEGO 2 (NUEVO) ---
    const capaUnir = document.getElementById("capa-unir");
    const canvasU = document.getElementById("canvasUnir");
    const ctxU = canvasU.getContext("2d");
    let unirActivo = false;
    let puntosUnir = [];
    let lineasHechas = [];
    let lineaEnCurso = null;
    let mision2Completada = false;

    // --- VARIABLES JUEGO PRINCIPAL ---
    let mensajeActual = "";
    let personajeActual = "";
    let retratoActual = "";
    canvas.width = 1000;
    canvas.height = 550;

    const imgFondo = new Image(); imgFondo.src = 'fondo.png'; 
    const imgQuieta = new Image(); imgQuieta.src = 'clauvienderech.png';
    const imgPaso1 = new Image(); imgPaso1.src = 'clauderechm.png';
    const imgPaso2 = new Image(); imgPaso2.src = 'clauderechamov.png';
    const imgZona1 = new Image(); imgZona1.src = 'pueslimon1.png'; 

    let imgPersonajeActual = imgQuieta; 
    let juegoActivo = false;
    let dialogoActivo = false;
    let dialogoCompletado = false; 
    let scrollFondo = 0;
    let indexTexto = 0; 

    const jugador = { x: 100, y: 230, ancho: 200, alto: 200, saltando: false, vy: 0, gravedad: 0.6 };
    const teclas = {};

    // --- LÓGICA DIÁLOGOS ---
    function typeWriter() {
        if (indexTexto < mensajeActual.length) {
            textoDialogo.innerHTML += mensajeActual.charAt(indexTexto);
            indexTexto++;
            setTimeout(typeWriter, 40);
        }
    }

    boxDialogo.addEventListener('click', () => {
        boxDialogo.classList.add("oculto");
        dialogoActivo = false;
        textoDialogo.innerHTML = "";
        indexTexto = 0;
        if (personajeActual === "Claudia:") {
            dialogoCompletado = true; 
            iniciarMiniJuego(); 
        } else if (personajeActual === "Eric:" && scrollFondo < -1300) {
            iniciarMisionUnir();
        }
    });

    // --- LÓGICA MINIJUEGO 1 (TECLAS) ---
    function iniciarMiniJuego() {
        capaMini.classList.remove("oculto");
        miniActivo = true;
        teclasLogradas = 0; imagenesLogradas = 0; tiempoMini = 100;
        imgCountText.innerText = "0";
        puntosCirculo.forEach(p => p.classList.remove("lleno"));
        nuevaLetra();
        bucleTimerMini();
    }

    function nuevaLetra() {
        const abc = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        letraActual = abc[Math.floor(Math.random() * abc.length)];
        teclaDisplay.innerText = letraActual;
    }

    function bucleTimerMini() {
        if (!miniActivo) return;
        tiempoMini -= 0.4; 
        barMini.style.width = tiempoMini + "%";
        if (tiempoMini <= 0) {
            alert("Falta cinta - REINTENTANDO");
            miniActivo = false;
            capaMini.classList.add("oculto");
            dialogoCompletado = false;
        } else { requestAnimationFrame(bucleTimerMini); }
    }

    // --- LÓGICA MINIJUEGO 2 (UNIR LETRAS) ---
    function iniciarMisionUnir() {
        capaUnir.classList.remove("oculto");
        unirActivo = true;
        puntosUnir = [];
        lineasHechas = [];
        const letrasMision = ['A', 'B', 'C', 'D', 'E'];
        letrasMision.forEach(l => {
            for(let i=0; i<2; i++) {
                puntosUnir.push({
                    x: Math.random() * (canvasU.width - 60) + 30,
                    y: Math.random() * (canvasU.height - 60) + 30,
                    char: l, conectado: false
                });
            }
        });
        renderUnir();
    }

    function renderUnir() {
        if (!unirActivo) return;
        ctxU.clearRect(0, 0, canvasU.width, canvasU.height);
        lineasHechas.forEach(l => {
            ctxU.beginPath(); ctxU.strokeStyle = '#00ff88'; ctxU.lineWidth = 3;
            ctxU.moveTo(l.start.x, l.start.y);
            l.path.forEach(p => ctxU.lineTo(p.x, p.y));
            ctxU.stroke();
        });
        if (lineaEnCurso) {
            ctxU.beginPath(); ctxU.strokeStyle = '#ff0000'; ctxU.lineWidth = 3;
            ctxU.moveTo(lineaEnCurso.start.x, lineaEnCurso.start.y);
            lineaEnCurso.path.forEach(p => ctxU.lineTo(p.x, p.y));
            ctxU.stroke();
        }
        puntosUnir.forEach(p => {
            ctxU.fillStyle = p.conectado ? '#00ff88' : '#fff';
            ctxU.beginPath(); ctxU.arc(p.x, p.y, 15, 0, Math.PI * 2); ctxU.fill();
            ctxU.fillStyle = '#000'; ctxU.font = 'bold 14px Arial';
            ctxU.textAlign = 'center'; ctxU.fillText(p.char, p.x, p.y + 5);
        });
        requestAnimationFrame(renderUnir);
    }

    canvasU.addEventListener('mousedown', e => {
        if(!unirActivo) return;
        const r = canvasU.getBoundingClientRect();
        const mx = e.clientX - r.left, my = e.clientY - r.top;
        puntosUnir.forEach(p => {
            if (!p.conectado && Math.hypot(p.x - mx, p.y - my) < 15) 
                lineaEnCurso = { start: p, path: [{x: mx, y: my}] };
        });
    });

    canvasU.addEventListener('mousemove', e => {
        if (!lineaEnCurso) return;
        const r = canvasU.getBoundingClientRect();
        const mx = e.clientX - r.left, my = e.clientY - r.top;
        const last = lineaEnCurso.path[lineaEnCurso.path.length-1];
        lineasHechas.forEach(l => {
            for(let i=0; i<l.path.length-1; i++) {
                if(verificarCruce(last.x, last.y, mx, my, l.path[i].x, l.path[i].y, l.path[i+1].x, l.path[i+1].y)) {
                    lineaEnCurso = null; alert("¡CORTE DE SEÑAL! No cruces las líneas.");
                    iniciarMisionUnir();
                }
            }
        });
        lineaEnCurso.path.push({x: mx, y: my});
    });

    canvasU.addEventListener('mouseup', e => {
        if (!lineaEnCurso) return;
        const r = canvasU.getBoundingClientRect();
        const mx = e.clientX - r.left, my = e.clientY - r.top;
        puntosUnir.forEach(p => {
            if (!p.conectado && p !== lineaEnCurso.start && p.char === lineaEnCurso.start.char && Math.hypot(p.x - mx, p.y - my) < 20) {
                p.conectado = true; lineaEnCurso.start.conectado = true;
                lineasHechas.push(lineaEnCurso);
            }
        });
        lineaEnCurso = null;
        if (lineasHechas.length === 5) {
            unirActivo = false; capaUnir.classList.add("oculto");
            mision2Completada = true;
            alert("SISTEMA RESTABLECIDO. CÓDIGO: 4412");
        }
    });

    function verificarCruce(x1, y1, x2, y2, x3, y3, x4, y4) {
        let det = (x2 - x1) * (y4 - y3) - (x4 - x3) * (y2 - y1);
        if (det === 0) return false;
        let l = ((y4 - y3) * (x4 - x1) + (x3 - x4) * (y4 - y1)) / det;
        let g = ((y1 - y2) * (x4 - x1) + (x2 - x1) * (y4 - y1)) / det;
        return (0 < l && l < 1) && (0 < g && g < 1);
    }

    // --- EVENTOS TECLADO ---
    window.addEventListener("keydown", (e) => {
        teclas[e.code] = true;
        if (e.code === "KeyE" && !avisoE.classList.contains("oculto") && !dialogoActivo && !miniActivo && !unirActivo) {
            if (scrollFondo < -300 && scrollFondo > -600 && !dialogoCompletado) {
                personajeActual = "Claudia:"; mensajeActual = "Eric, amigo mío. Un entrenador de tanto calibre merecía ver esto en primera fila.";
                retratoActual = "clauicon.png"; iniciarDialogo();
            }
            else if (scrollFondo < -1300 && scrollFondo > -1600 && !mision2Completada) {
                personajeActual = "Eric:"; mensajeActual = "¿Qué está pasando con el sistema? Siento una interferencia...";
                retratoActual = "ericicon.png"; iniciarDialogo();
            }
            else if (scrollFondo < -2300 && scrollFondo > -2600) {
                personajeActual = "Eric:"; mensajeActual = "Papaloteee... Ya te vi Papalote";
                retratoActual = "ericicon.png"; iniciarDialogo();
            }
        }
        if (miniActivo && e.key.toUpperCase() === letraActual) {
            teclasLogradas++; tiempoMini = Math.min(tiempoMini + 15, 100); 
            if (teclasLogradas === 5) {
                imagenesLogradas++; teclasLogradas = 0; imgCountText.innerText = imagenesLogradas;
                imgMini.src = `https://picsum.photos/400/300?sig=${Math.random()}`;
                if (imagenesLogradas === 3) { miniActivo = false; capaMini.classList.add("oculto"); alert("TE AGRADEZCO"); }
            }
            puntosCirculo.forEach((p, i) => p.classList.toggle("lleno", i < teclasLogradas));
            nuevaLetra();
        }
    });

    window.addEventListener("keyup", (e) => teclas[e.code] = false);

    // --- BUCLE PRINCIPAL ---
    function comenzarJuego() {
        menu.classList.add("oculto"); btnVolverJuego.classList.remove("oculto"); 
        juegoActivo = true; bucle();
    }

    function iniciarDialogo() {
        dialogoActivo = true; iconoMision.classList.add("oculto"); 
        nombreDialogo.innerText = personajeActual; imgRetrato.src = retratoActual;
        boxDialogo.classList.remove("oculto"); avisoE.classList.add("oculto"); typeWriter();
    }

    function actualizar() {
        if (!juegoActivo || dialogoActivo || miniActivo || unirActivo) return;
        let mov = false;
        if (teclas["ArrowRight"]) { scrollFondo -= 4; mov = true; }
        if (teclas["ArrowLeft"]) { scrollFondo += 4; mov = true; }
        imgPersonajeActual = mov ? (Math.floor(Date.now() / 150) % 2 === 0 ? imgPaso1 : imgPaso2) : imgQuieta;
        const z1 = (scrollFondo < -300 && scrollFondo > -600 && !dialogoCompletado);
        const z2 = (scrollFondo < -1300 && scrollFondo > -1600 && !mision2Completada);
        const z3 = (scrollFondo < -2300 && scrollFondo > -2600);
        if (z1 || z2 || z3) {
            avisoE.classList.remove("oculto"); iconoMision.classList.remove("oculto");
            iconoMision.style.left = (jugador.x + 330) + "px"; iconoMision.style.top = (jugador.y - 70) + "px"; 
        } else { avisoE.classList.add("oculto"); iconoMision.classList.add("oculto"); }
        if (teclas["Space"] && !jugador.saltando) { jugador.vy = -15; jugador.saltando = true; }
        jugador.vy += jugador.gravedad; jugador.y += jugador.vy;
        if (jugador.y > 230) { jugador.y = 230; jugador.vy = 0; jugador.saltando = false; }
    }

    function dibujar() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        let xRel = scrollFondo % canvas.width;
        ctx.drawImage(imgFondo, xRel, 0, canvas.width, canvas.height);
        ctx.drawImage(imgFondo, xRel + canvas.width, 0, canvas.width, canvas.height);
        ctx.drawImage(imgFondo, xRel - canvas.width, 0, canvas.width, canvas.height);
        if (!dialogoCompletado) ctx.drawImage(imgZona1, 550 + scrollFondo, 200, 230, 200);
        ctx.drawImage(imgPersonajeActual, jugador.x, jugador.y, jugador.ancho, jugador.alto);
    }

    function bucle() {
        if (!juegoActivo) return; actualizar(); dibujar(); requestAnimationFrame(bucle);
    }

    // --- AJUSTES ---
    function ajustarVolumen() { musicaFondo.volume = document.getElementById("slider-volumen").value / 100; }
    function ajustarBrillo() { document.getElementById("contenedor-juego").style.filter = `brightness(${document.getElementById("rango-brillo").value}%)`; }
    function cerrarAjustes() { ajustes.classList.add("oculto"); menu.classList.remove("oculto"); }
    function abrirAjustes() { menu.classList.add("oculto"); ajustes.classList.remove("oculto"); }
    function volverAlMenu() { location.reload(); }
    function toggleFullscreen() { /* Opcional: Implementar fullscreen */ }
</script>
</body>
</html>
