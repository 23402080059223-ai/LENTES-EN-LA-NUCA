<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Minijuego: Infiltración en el Nodo (Corregido)</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0d0d0d;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Press Start 2P', cursive;
            color: #00ffff;
        }

        #contenedor-laberinto {
            width: 500px;
            background: #000;
            border: 4px solid #00ffff;
            padding: 20px;
            text-align: center;
            box-shadow: 0 0 20px #00ffff;
        }

        canvas {
            background: #111;
            border: 2px solid #333;
            display: block;
            margin: 20px auto;
            cursor: none; 
        }

        #status {
            font-size: 10px;
            margin-bottom: 10px;
            height: 20px;
        }

        .instrucciones {
            font-size: 8px;
            color: #777;
            margin-top: 10px;
        }

        button {
            background: transparent;
            color: #00ffff;
            border: 2px solid #00ffff;
            padding: 10px 20px;
            font-family: 'Press Start 2P', cursive;
            cursor: pointer;
        }

        button:hover { background: #00ffff; color: #000; }
    </style>
</head>
<body>

<div id="contenedor-laberinto">
    <div style="font-size: 12px;">INFILTRACIÓN DE NODO</div>
    <div id="status">LLEGA AL NÚCLEO VERDE</div>

    <canvas id="canvasLaberinto" width="400" height="300"></canvas>

    <div class="instrucciones">USA EL MOUSE PARA MOVERTE<br>EVITA EL RASTREO (ROJO)</div>
    <br>
    <button id="btn-inicio" onclick="iniciarJuego()">INICIAR BYPASS</button>
</div>

<script>
    const canvas = document.getElementById('canvasLaberinto');
    const ctx = canvas.getContext('2d');
    const statusTxt = document.getElementById('status');
    const btnInicio = document.getElementById('btn-inicio');

    let juegoActivo = false;
    // Guardamos la posición inicial para resetearla siempre
    const posInicial = { x: 30, y: 150 };
    let jugador = { x: posInicial.x, y: posInicial.y, radio: 8 };
    let meta = { x: 370, y: 135, ancho: 30, alto: 30 };
    
    let obstaculos = [
        { x: 100, y: 0, ancho: 20, alto: 180, v: 2 },
        { x: 180, y: 120, ancho: 20, alto: 180, v: -3 },
        { x: 260, y: 0, ancho: 20, alto: 180, v: 4 },
        { x: 330, y: 120, ancho: 20, alto: 180, v: -2.5 }
    ];

    function iniciarJuego() {
        // Reset de posición al iniciar
        jugador.x = posInicial.x;
        jugador.y = posInicial.y;
        juegoActivo = true;
        btnInicio.style.display = 'none';
        statusTxt.innerText = "¡EVADE LOS CORTAFUEGOS!";
        statusTxt.style.color = "#00ffff";
        bucle();
    }

    canvas.addEventListener('mousemove', (e) => {
        if (!juegoActivo) return;
        const rect = canvas.getBoundingClientRect();
        // Limitamos el movimiento del jugador dentro del canvas
        jugador.x = e.clientX - rect.left;
        jugador.y = e.clientY - rect.top;
    });

    function bucle() {
        if (!juegoActivo) return;
        actualizar();
        dibujar();
        requestAnimationFrame(bucle);
    }

    function actualizar() {
        obstaculos.forEach(obs => {
            obs.y += obs.v;
            if (obs.y + obs.alto > canvas.height || obs.y < 0) {
                obs.v *= -1;
            }

            // Colisión circular vs rectangular
            if (jugador.x + jugador.radio > obs.x && 
                jugador.x - jugador.radio < obs.x + obs.ancho &&
                jugador.y + jugador.radio > obs.y && 
                jugador.y - jugador.radio < obs.y + obs.alto) {
                perder();
            }
        });

        if (jugador.x + jugador.radio > meta.x && 
            jugador.x - jugador.radio < meta.x + meta.ancho &&
            jugador.y + jugador.radio > meta.y && 
            jugador.y - jugador.radio < meta.y + meta.alto) {
            ganar();
        }
    }

    function dibujar() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Meta
        ctx.fillStyle = "#00ff00";
        ctx.fillRect(meta.x, meta.y, meta.ancho, meta.alto);

        // Obstáculos
        ctx.fillStyle = "#ff0000";
        obstaculos.forEach(obs => {
            ctx.fillRect(obs.x, obs.y, obs.ancho, obs.alto);
        });

        // Jugador
        ctx.fillStyle = "#00ffff";
        ctx.beginPath();
        ctx.arc(jugador.x, jugador.y, jugador.radio, 0, Math.PI * 2);
        ctx.fill();
    }

    function ganar() {
        juegoActivo = false;
        statusTxt.innerText = "ACCESO COMPLETO";
        statusTxt.style.color = "#00ff00";
        setTimeout(() => {
            alert("Nodo hackeado con éxito.\nCódigo final: 7741");
            reiniciarParametros();
        }, 100);
    }

    function perder() {
        juegoActivo = false; // Detenemos el bucle inmediatamente
        statusTxt.innerText = "RASTREO DETECTADO";
        statusTxt.style.color = "#ff0000";
        
        // El truco está aquí: movemos al jugador LEJOS de los obstáculos antes del alert
        jugador.x = posInicial.x;
        jugador.y = posInicial.y;

        setTimeout(() => {
            alert("¡COLISIÓN! El sistema te ha expulsado.");
            reiniciarParametros();
        }, 100);
    }

    function reiniciarParametros() {
        juegoActivo = false;
        btnInicio.style.display = 'inline-block';
        btnInicio.innerText = "REINTENTAR";
        // Limpiamos el dibujo para que no se vea el error
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        // Aseguramos posición inicial
        jugador.x = posInicial.x;
        jugador.y = posInicial.y;
    }
</script>

</body>
</html>
